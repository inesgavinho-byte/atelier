# ATELIER execution worker — environment (set these in Railway, not committed).

# Supabase "Atelier" project. SERVICE ROLE ONLY — the jobs table is RLS-locked
# to it. Never put the anon key here.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Context agent (ADR-0004): summarises each active workspace's conversation
# hourly via Anthropic (Haiku). Used directly by the worker — NOT via the
# ATELIER gateway. Without it the context agent stays inactive (logs and skips).
ANTHROPIC_API_KEY=

# OpenAI — used by the embeddings backfill (RAG v2): embeds document chunks that
# have no vector yet so they become semantically searchable. Without it the
# backfill loop stays idle. OPENAI_EMBED_MODEL defaults to text-embedding-3-small.
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# Telegram (ADR-0003 + ADR-0006). Without TELEGRAM_BOT_TOKEN the bot stays
# inactive. TELEGRAM_CHAT_ID restricts who can command the bot in private chat.
# TELEGRAM_USER_ID is the target for the daily Conversation Watch briefing
# (defaults to TELEGRAM_CHAT_ID). For Conversation Watch to see group messages,
# disable the bot's privacy mode in @BotFather (/setprivacy → Disable).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_USER_ID=
# Model used to analyse group messages (Conversation Watch). Haiku — cheap.
WORKER_WATCH_MODEL=claude-haiku-4-5-20251001

# Optional tuning.
WORKER_POLL_MS=5000
WORKER_SIMULATE_MS=3000
# Context agent cadence + look-back window (ms). Default hourly.
WORKER_CONTEXT_MS=3600000
WORKER_CONTEXT_WINDOW_MS=3600000
WORKER_CONTEXT_MODEL=claude-haiku-4-5-20251001
# Embeddings backfill cadence (ms). Default 10 min.
WORKER_EMBED_BACKFILL_MS=600000
