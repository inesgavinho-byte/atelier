# ATELIER MarkItDown service — environment.
# Copy to .env for local runs; set the same in the Railway service.

# Optional shared secret. When set, /convert requires
# `Authorization: Bearer <token>`. Must match MARKITDOWN_TOKEN in the web app.
MARKITDOWN_TOKEN=

# Max upload size in bytes (backstop; the web app caps far lower). Default 25MB.
MARKITDOWN_MAX_BYTES=26214400

# Port. Railway injects this automatically; only needed for local runs.
PORT=8000
