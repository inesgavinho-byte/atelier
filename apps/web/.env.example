# ATELIER — environment configuration
# Copy to .env.local with real values. Set the same in the Netlify UI.
# Nothing here is required to build; missing values degrade gracefully.

# ── Supabase (required for any real data) ───────────────────────────────────
# The "Atelier" project. The anon key is read server-side only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Service role — required to manage connector credentials from /ecosystem
# (the connector_credentials table is RLS-locked to the service role).
SUPABASE_SERVICE_ROLE_KEY=
# Personal access token for the Supabase Management API. Enables per-workspace
# database info (tables, row counts) and the Council's read-only SQL tools.
SUPABASE_ACCESS_TOKEN=

# ── Access gate (optional, recommended in production) ───────────────────────
# When ATELIER_ACCESS_PASSWORD is set, the whole app is behind a single shared
# password (a /login screen). When unset, the gate is OFF and the app is open
# exactly as before — there is no lockout risk.
ATELIER_ACCESS_PASSWORD=
# Optional dedicated secret for signing the session cookie. If unset, the
# password itself signs it (changing the password then invalidates sessions).
ATELIER_SESSION_SECRET=

# ── Connector credential encryption (optional) ──────────────────────────────
# When set, connector credentials are encrypted at rest (AES-256-GCM).
# Without it they are stored in clear and flagged as insecure in the UI.
ATELIER_CRED_KEY=

# ── AI providers (optional — each connector shows "Credenciais em falta") ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
# Groq — ultra-fast inference (Llama/Mixtral), OpenAI-compatible API.
GROQ_API_KEY=
# DeepSeek — cheap, code-specialised models (V3 chat + reasoner).
DEEPSEEK_API_KEY=

# ── Agenda (optional) ───────────────────────────────────────────────────────
# A calendar ICS feed URL (Google/Outlook/Apple all publish one). Feeds today's
# events into the home "Agenda de Hoje". Can also be set from /ecosystem (stored
# encrypted; the fetch happens server-side, the URL never reaches the browser).
ICS_CALENDAR_URL=
# Timezone used to decide what "today" means and to label times. Default below.
ATELIER_TIMEZONE=Europe/Lisbon

# ── Document conversion — MarkItDown service (optional) ─────────────────────
# URL of the apps/markitdown service (Python on Railway). When set, PDF/Office/
# image uploads are converted to Markdown; when unset they wait as
# 'pending_conversion' (the pipeline degrades gracefully). MARKITDOWN_TOKEN, if
# set, must match the service's own token.
MARKITDOWN_URL=
MARKITDOWN_TOKEN=

# ── Developer / deploy connectors (optional) ────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=

# ── Telegram (optional — worker only, ADR-0003) ─────────────────────────────
# Create a bot with @BotFather → token. Without it the bot stays inactive.
# TELEGRAM_CHAT_ID restricts who can command the bot and is the target for
# proactive notifications (your own chat id). Get it from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
