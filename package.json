{
  "name": "atelier",
  "version": "0.1.0",
  "private": true,
  "description": "ATELIER — Foundation Repository. Source of truth for the product code and the intellectual foundation.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @atelier/web",
    "build": "npm run build --workspace @atelier/web",
    "start": "npm run start --workspace @atelier/web",
    "lint": "npm run lint --workspace @atelier/web",
    "typecheck": "npm run typecheck --workspace @atelier/web",
    "test": "npm run test --workspace @atelier/web"
  }
}
